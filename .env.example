# ==============================================
# Moveact 口コミ生成アプリ 環境変数
# cp .env.example .env で作成し、値を設定してください
# ==============================================

# --- データベース (MySQL) ---
DATABASE_URL=mysql://username:password@localhost:3306/moveact_kuchikomi

# --- AI (Google Gemini / OpenAI互換エンドポイント経由) ---
# Google AI Studio (https://aistudio.google.com/apikey) で発行した APIキー(AIza...)。
GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXXXXXXXXXXX
# 既定で Gemini の OpenAI互換エンドポイントを使うため通常は未設定でOK。
GEMINI_BASE_URL=
# 例: gemini-2.5-flash（高品質）/ gemini-2.5-flash-lite（低コスト・高速）
GEMINI_MODEL=gemini-2.5-flash

# --- サーバー ---
PORT=3001
