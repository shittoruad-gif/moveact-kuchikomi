# ==============================================
# Moveact 口コミ生成アプリ 環境変数
# cp .env.example .env で作成し、値を設定してください
# ==============================================

# --- データベース (MySQL) ---
DATABASE_URL=mysql://username:password@localhost:3306/moveact_kuchikomi

# --- AI (OpenAI互換 LLM API) ---
# OpenAI公式なら OPENAI_BASE_URL は空でOK。
# 互換API（Azure/OpenRouter/ローカル等）を使う場合はエンドポイントを設定。
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# --- サーバー ---
PORT=3001
